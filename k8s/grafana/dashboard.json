{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "version": "" },
    { "type": "panel", "id": "stat", "version": "" },
    { "type": "panel", "id": "gauge", "version": "" }
  ],
  "title": "PlantGuard — ML Observability",
  "uid": "plantguard-v1",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Predictions (1h)",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(increase(plantguard_predictions_total[1h]))",
          "legendFormat": "Predictions"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Prediction Rate (req/min)",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(plantguard_predictions_total[5m])) * 60",
          "legendFormat": "req/min"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Rejection Rate",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(plantguard_guard_decisions_total{decision=\"rejected\"}[5m])) / sum(rate(plantguard_guard_decisions_total[5m]))",
          "legendFormat": "Rejection %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.2, "color": "yellow" },
              { "value": 0.5, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 Inference Latency",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(plantguard_inference_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.5, "color": "yellow" },
              { "value": 1.5, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Prediction Rate by Label",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(plantguard_predictions_total{prediction=\"HEALTHY\"}[5m])",
          "legendFormat": "HEALTHY"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(plantguard_predictions_total{prediction=\"DISEASED\"}[5m])",
          "legendFormat": "DISEASED"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Inference Latency Percentiles",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum(rate(plantguard_inference_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(plantguard_inference_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum(rate(plantguard_inference_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Mean Confidence Score by Prediction",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(plantguard_confidence_score_sum{prediction=\"HEALTHY\"}[5m]) / rate(plantguard_confidence_score_count{prediction=\"HEALTHY\"}[5m])",
          "legendFormat": "Mean confidence — HEALTHY"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(plantguard_confidence_score_sum{prediction=\"DISEASED\"}[5m]) / rate(plantguard_confidence_score_count{prediction=\"DISEASED\"}[5m])",
          "legendFormat": "Mean confidence — DISEASED"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Leaf Similarity Score Distribution (mean)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(plantguard_leaf_similarity_score_sum{decision=\"accepted\"}[5m]) / rate(plantguard_leaf_similarity_score_count{decision=\"accepted\"}[5m])",
          "legendFormat": "Mean similarity — accepted"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "rate(plantguard_leaf_similarity_score_sum{decision=\"rejected\"}[5m]) / rate(plantguard_leaf_similarity_score_count{decision=\"rejected\"}[5m])",
          "legendFormat": "Mean similarity — rejected"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Component Latency Breakdown",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(plantguard_feature_extraction_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 EfficientNet embedding"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum(rate(plantguard_classifier_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 Classifier (XGBoost/RF/LR)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP Error Rate",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(http_requests_total{status=~\"4..|5..\"}[5m])) by (status)",
          "legendFormat": "HTTP {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      }
    }
  ]
}
